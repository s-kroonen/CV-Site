# SQLite database file (mount a Docker volume over its parent dir in prod)
DATABASE_URL="file:./prisma/dev.db"

# Directory for uploaded images (project screenshots, avatar). Mount a Docker
# volume over this path in prod; unset/unused in local dev.
UPLOAD_DIR=""

# Base URL of the deployed site (used for WebAuthn relying-party id + absolute links)
SITE_URL="http://localhost:3000"

# --- Admin session ---
# Long random string used to sign/encrypt the admin session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=""

# --- Cloudflare Turnstile (contact form + private-info reveal) ---
# Defaults below are Cloudflare's published "always passes" test keys - fine
# for local dev, but replace both with real keys from your Cloudflare
# dashboard before deploying (https://developers.cloudflare.com/turnstile/troubleshooting/testing/).
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# --- Outbound mail (contact form notifications) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM=""
